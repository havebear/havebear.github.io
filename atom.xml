    <title>手绘风格图表 chart.xkcd</title>
    <link href="http://havebear.com/2023/09/12/%E7%A8%8B%E5%BA%8F%E5%91%98/%E5%89%8D%E7%AB%AF/%E5%A4%87%E5%BF%98%E5%BD%95/%E6%89%8B%E7%BB%98%E9%A3%8E%E6%A0%BC%E5%9B%BE%E8%A1%A8%20chart.xkcd/"/>
    <id>http://havebear.com/2023/09/12/%E7%A8%8B%E5%BA%8F%E5%91%98/%E5%89%8D%E7%AB%AF/%E5%A4%87%E5%BF%98%E5%BD%95/%E6%89%8B%E7%BB%98%E9%A3%8E%E6%A0%BC%E5%9B%BE%E8%A1%A8%20chart.xkcd/</id>
